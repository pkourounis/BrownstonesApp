# Copy to .env.local and fill in. Never commit real values.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Used for privileged actions (inviting staff, sending push).
# Keep this secret — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Web Push (VAPID) ---
# Generate once with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@brownstones.com
